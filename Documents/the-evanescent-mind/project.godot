LimerenceTracker="*res://autoloads/LimerenceTracker.gd"
NarrativeManager="*res://autoloads/NarrativeManager.gd"
DynamicAudioManager="*res://autoloads/DynamicAudioManager.gd"
EndingSystem="*res://autoloads/EndingSystem.gd"
SaveSystem="*res://scripts/systems/SaveSystem.gd"
PhantomCameraManager="*uid://duq6jhf6unyis"
Dialogic="*uid://ds2q0uclmolvu"
ProjectionSequenceManager="*res://autoloads/ProjectionSequenceManager.gd"
ZoneManager="*res://autoloads/ZoneManager.gd"

[dialogic]

directories/dch_directory={}
directories/dtl_directory={}
layout/style_directory={}

[dotnet]

project/assembly_name="The Evanescent Mind"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

